#include<stdio.h>
int main()
{
    int n1,n2,n3,max,result;
    printf("Enter number n1 :");
    scanf("%d",&n1);
    printf("Enter number n2 :");
    scanf("%d",&n2);
    printf("Enter number n3 :");
    scanf("%d",&n3);
    max=(n1>n2)?n1:n2;
    printf("The largest number is : %d\n",max);
    result=max*n3;
    printf("The result of multiplication is : %d",result);
    return 0;
}
