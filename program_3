#include<stdio.h>
int main()
{
    float maths,english,science,computer,grammer,total,percentage;

    printf("Enter your marks: \n");

    printf("maths");
    scanf("%f",&maths);
    printf("english");
    scanf("%f",&english);
    printf("science");
    scanf("%f",&science);
    printf("computer");
    scanf("%f",&computer);
    printf("grammer");
    scanf("%f",&grammer);

    total=maths+english+science+computer+grammer;
    printf("total marks is: %f",total);

    percentage=total/5*100;

    printf("\n percentage is : %f",percentage);
    return 0;
}
