#include<stdio.h>
void main()
{
 int limit,num,pos=0,neg=0,zero=0;
 printf("Enter the limit:\n");
 scanf("%d",&limit);
 printf("Enter %d numbers\n",limit);
 while(limit)
 {
 scanf("%d",&num);
 if(num>0)
 {
 pos++;
 }
 else if(num<0)
 {
 neg++;
 }
 else
 {
 zero++;
 }
 limit--;
 }
 printf("\n Positive numbers:%d\n",pos);
 printf("\n Negative numbers:%d\n",neg);
 printf("\n Zero numbers:%d\n",zero);
 }
