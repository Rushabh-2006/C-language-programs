#include <stdio.h>
#include <string.h>

void reverse(char str[]) {
    int i, len = strlen(str);
    char temp;

    for (i = 0; i < len / 2; i++) {
        temp = str[i];
        str[i] = str[len - i - 1];
        str[len - i - 1] = temp;
    }
}

int main() {
    char ch[10] = "hbahsur";

    reverse(ch);

    printf("Reversed string = %s\n", ch);

    return 0;
}
